# CareOrchestra Environment Configuration
# Copy this file to .env and customize for your environment

# ============================================================================
# Google Cloud Configuration
# ============================================================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
BIGQUERY_DATASET=care_orchestra
# Path to Google service-account JSON for ADC (required for real BigQuery access)
GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account.json

# Gemini API key (required for real AI responses from Coordinator/Vitals/Medication)
GOOGLE_API_KEY=your-google-api-key

# Groq API key (required for real SymptomsAgent LLM calls)
GROQ_API_KEY=your-groq-api-key

# ============================================================================
# Gmail Integration Configuration
# ============================================================================
GMAIL_SENDER_EMAIL=alerts@careorchestra.app
# Set to false for real Gmail integration, true for mock/development
GMAIL_USE_MOCK=true

# --- Real Gmail (Domain-Wide Delegation) setup ---
# Required when GMAIL_USE_MOCK=false.
#
# Prerequisites (Google Workspace Admin):
#   1. Enable the Gmail API in your GCP project.
#   2. Create a Service Account and download the JSON key.
#   3. In the Workspace Admin console → Security → API Controls →
#      Domain-wide Delegation, add the service account client ID with scope:
#        https://www.googleapis.com/auth/gmail.send
#
# Path to the service-account JSON key file.
# Falls back to GOOGLE_APPLICATION_CREDENTIALS if not set.
GMAIL_CREDENTIALS_PATH=/path/to/gmail-service-account.json

# Workspace account the service account will impersonate (usually the same
# as GMAIL_SENDER_EMAIL, but can differ if you use a shared mailbox).
GMAIL_DELEGATED_ACCOUNT=alerts@careorchestra.app

# ============================================================================
# Google Calendar Integration Configuration
# ============================================================================
CALENDAR_ID=primary
# Set to false for real Calendar integration, true for mock/development
CALENDAR_USE_MOCK=true

# ============================================================================
# Application Configuration
# ============================================================================
# Enable debug mode for verbose logging
DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable Google Cloud Logging sink. Keep false unless the service account
# has permission: logging.logEntries.create
ENABLE_GCP_LOGGING=false

# Use mock data for development/testing (set to false with real data)
USE_MOCK_DATA=true

# Path to mock payload files
MOCK_DATA_PATH=data/mock_payloads

# ============================================================================
# ADK Configuration (Agent Development Kit)
# ============================================================================
# ADK credentials and settings go here
# ADK_PROJECT_ID=your-adk-project-id
# ADK_LOCATION=us-central1
# ADK_MODEL=gemini-2.0-flash  # or other supported model

# ============================================================================
# Database Configuration
# ============================================================================
# BigQuery settings
BQ_BATCH_SIZE=1000
BQ_TIMEOUT_SECONDS=30

# ============================================================================
# Service Configuration
# ============================================================================
# API timeout in seconds
API_TIMEOUT=30

# Patient service settings
PATIENT_CACHE_TTL=3600

# ============================================================================
# API / Frontend Configuration
# ============================================================================
# Comma-separated list of allowed CORS origins. Defaults to * (all) if unset.
# In production, restrict to your frontend domain(s), e.g.:
# CORS_ORIGINS=https://careorchestra.app,https://www.careorchestra.app
CORS_ORIGINS=*


# Add provider email addresses for escalation alerts
PROVIDER_EMAILS=doctor1@clinic.com,doctor2@clinic.com
